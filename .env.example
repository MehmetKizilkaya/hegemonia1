# PostgreSQL (Neon önerilir — ücretsiz)
DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require

# API (Railway)
PORT=3001
NODE_ENV=production
# Vercel URL — birden fazla için virgülle ayırın
CORS_ORIGIN=https://hegemonia.vercel.app

# Firebase Admin (Railway — backend)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# İlk test için true; Firebase kurulunca false
DEV_AUTH_BYPASS=true

# Firebase Web (Vercel — build time, VITE_ prefix)
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123
# Railway API public URL (sonunda / yok)
VITE_API_URL=https://hegemonia-api-production.up.railway.app
