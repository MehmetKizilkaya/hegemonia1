{
  "name": "@hegemonia/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:migrate:prod": "node dist/db/migrate.js",
    "db:seed": "tsx src/db/seed/index.ts",
    "db:seed:prod": "node dist/db/seed/index.js"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/rate-limit": "^10.2.0",
    "@hegemonia/shared": "file:../../packages/shared",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.38.2",
    "fastify": "^5.2.0",
    "firebase-admin": "^13.0.1",
    "pg": "^8.13.1",
    "pg-boss": "^10.1.5",
    "socket.io": "^4.8.1",
    "uuid": "^11.0.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "@types/uuid": "^10.0.0",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
